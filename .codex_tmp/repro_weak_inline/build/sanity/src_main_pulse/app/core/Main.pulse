package app.core;
import pulse.lang.IO;
import pulse.memory.Memory;
import pulse.rt.Intrinsics;

class Main {
    public static void main() {
        String h = "42";
        long w = Memory.weakNew(h);
        IO.println(Intrinsics.stringLength(Memory.weakGet(w)));
        Memory.release(h);
        String dropped = Memory.weakGet(w);
        if (dropped == null) { IO.println(0); } else { IO.println(dropped.length()); }
    }
}
