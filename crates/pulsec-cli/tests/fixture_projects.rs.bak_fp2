        &counter,
        r#"
        package app.core;
        import com.pulse.lang.IO;

        class Counter {
            int value;

            public Counter() {
                this.value = 1;
                IO.println("ctor");
            }

            public void bump() {
                this.value = this.value + 1;
                IO.println("bump");
            }

            public int read() {
                return this.value;
            }
        }
        "#,
    );
    write_file(
        &entry,
        r#"
        package app.core;
        import com.pulse.lang.IO;

        class Main {
            public static void main() {
                Counter c = new Counter();
                c.bump();
                c.read();
                IO.println("done");
            }
        }
        "#,
    );

