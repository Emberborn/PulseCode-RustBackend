    assert_eq!(out, "math start\nmath done\n");

    let _ = fs::remove_dir_all(root);
}

#[test]
fn cli_build_executes_cross_file_instance_call_baseline() {
    let root = unique_temp_root();
    let src_root = root.join("src");
    let entry = src_root.join("app/core/Main.pulse");
    let helper = src_root.join("app/core/Greeter.pulse");

    write_file(
        &helper,
        r#"
        package app.core;
        import com.pulse.lang.IO;

        class Greeter {
            public void ping() {
                IO.print("hello");
                IO.println(" world");
            }
        }
        "#,
    );
    write_file(
        &entry,
        r#"
        package app.core;

        class Main {
            public static void main() {
                Greeter g = new Greeter();
                g.ping();
            }
        }
        "#,
    );

    let output = Command::new(env!("CARGO_BIN_EXE_pulsec"))
        .arg("build")
