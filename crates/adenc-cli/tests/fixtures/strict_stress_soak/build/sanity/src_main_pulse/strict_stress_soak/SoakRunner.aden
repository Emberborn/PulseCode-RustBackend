package strict_stress_soak;

import aden.collections.ArrayList;
import aden.collections.HashMap;
import aden.collections.HashSet;
import aden.collections.LinkedList;
import aden.lang.Integer;

class SoakRunner {
    public int run(int rounds) {
        ArrayList values = new ArrayList();
        LinkedList queue = new LinkedList();
        HashMap stats = new HashMap();
        HashSet tags = new HashSet();

        String churn = "x";
        int sum = 0;
        int i = 0;
        int parity = 0;
        int drained = 0;

        while (i < rounds) {
            Token token = new Token(i + 1);
            int v = token.value();
            String boxed = Integer.toString(v);

            values.add(boxed);
            if (values.size() > 48) {
                values.clear();
            }

            queue.offer(boxed);
            if (queue.size() > 32) {
                String nextText = (String) queue.poll();
                int next = Integer.parse(nextText);
                drained = drained + next;
            }

            stats.put("last", Integer.toString(v));

            if (parity == 0) {
                tags.add("even");
                parity = 1;
            } else {
                tags.add("odd");
                parity = 0;
            }

            churn = churn.concat("a");
            if (churn.length() > 32) {
                churn = "x";
            }

            sum = sum + v;
            i = i + 1;
        }

        while (queue.size() > 0) {
            String nextText = (String) queue.poll();
            int next = Integer.parse(nextText);
            drained = drained + next;
        }

        int last = Integer.parse((String) stats.get("last"));
        int unique = tags.size();
        int count = values.size();
        return sum + drained + last + unique + count + churn.length();
    }
}
