package author.project;

import pulse.collections.ArrayList;
import pulse.collections.List;
import pulse.io.File;
import pulse.io.Files;
import pulse.io.Path;
import pulse.lang.String;
import pulse.util.Objects;

/**
 * Filesystem-backed project and workspace discovery helpers for privileged authoring flows.
 */
public final class ProjectDiscovery {
    /**
     * Finds the nearest manifest path at or above the supplied start path, or null when none exists.
     */
    public static String findManifestPath(String startPath) {
        String start = Path.normalize((String) Objects.requireNonNull(startPath, "startPath must not be null"));
        if (start.isEmpty()) {
            return null;
        }
        if (File.isFile(start) && Path.fileName(start).equals("pulsec.toml")) {
            return start;
        }
        String dir = start;
        if (File.isFile(start)) {
            dir = Path.parent(start);
        }
        while (!dir.isEmpty()) {
            String candidate = Path.resolve(dir, "pulsec.toml");
            if (File.isFile(candidate)) {
                return candidate;
            }
            String parent = Path.parent(dir);
            if (parent.isEmpty() || parent.equals(dir)) {
                break;
            }
            dir = parent;
        }
        return null;
    }

    /**
     * Finds the nearest project root at or above the supplied start path, or null when no manifest exists.
     */
    public static String findProjectRoot(String startPath) {
        String manifestPath = ProjectDiscovery.findManifestPath(startPath);
        if (manifestPath == null) {
            return null;
        }
        return Path.parent(manifestPath);
    }

    /**
     * Loads one manifest file into the current author.project model surface.
     */
    public static ProjectManifest loadManifest(String manifestPath) {
        String normalized = Path.normalize((String) Objects.requireNonNull(manifestPath, "manifestPath must not be null"));
        if (!File.isFile(normalized)) {
            pulse.rt.Intrinsics.panic(
                "Manifest load error: manifest '".concat(normalized).concat("' does not exist")
            );
        }
        String text = File.readAllText(normalized);
        if (text == null) {
            pulse.rt.Intrinsics.panic(
                "Manifest load error: manifest '".concat(normalized).concat("' could not be read")
            );
        }
        return new ProjectManifestParser(Path.parent(normalized)).parse(text);
    }

    /**
     * Finds and loads the nearest manifest at or above the supplied start path, or null when none exists.
     */
    public static ProjectManifest findAndLoadManifest(String startPath) {
        String manifestPath = ProjectDiscovery.findManifestPath(startPath);
        if (manifestPath == null) {
            return null;
        }
        return ProjectDiscovery.loadManifest(manifestPath);
    }

    /**
     * Resolves workspace member project roots against the filesystem-backed manifest contract.
     */
    public static List<String> resolveWorkspaceMemberProjectRoots(
        String workspaceRoot,
        WorkspaceManifest workspace
    ) {
        String root = Path.normalize((String) Objects.requireNonNull(workspaceRoot, "workspaceRoot must not be null"));
        WorkspaceManifest resolvedWorkspace =
            (WorkspaceManifest) Objects.requireNonNull(workspace, "workspace must not be null");
        ArrayList<String> out = new ArrayList<String>();
        int index = 0;
        while (index < resolvedWorkspace.size()) {
            String raw = resolvedWorkspace.member(index);
            String memberRoot = raw;
            if (!Path.isAbsolute(memberRoot)) {
                memberRoot = Path.resolve(root, memberRoot);
            }
            memberRoot = Path.normalize(memberRoot);
            String manifestPath = Path.resolve(memberRoot, "pulsec.toml");
            if (!File.isFile(manifestPath)) {
                pulse.rt.Intrinsics.panic(
                    "Workspace member '".concat(raw)
                        .concat("' is missing manifest '")
                        .concat(manifestPath)
                        .concat("'")
                );
            }
            ProjectManifest memberManifest = ProjectDiscovery.loadManifest(manifestPath);
            if (memberManifest.workspace() != null) {
                pulse.rt.Intrinsics.panic(
                    "Workspace member '".concat(raw).concat("' cannot declare [workspace]")
                );
            }
            ProjectDiscovery.addSortedDistinct(out, memberRoot);
            index = index + 1;
        }
        if (out.isEmpty()) {
            pulse.rt.Intrinsics.panic(
                "Manifest validation error: [workspace].members must resolve to at least one member project"
            );
        }
        return out;
    }

    /**
     * Discovers the entry file under the supplied source root using the current CLI policy.
     */
    public static String discoverEntryPath(String sourceRoot) {
        String root = Path.normalize((String) Objects.requireNonNull(sourceRoot, "sourceRoot must not be null"));
        if (!File.isDirectory(root)) {
            return null;
        }
        String candidate = Path.resolve(root, "app/main/Main.pulse");
        if (File.isFile(candidate)) {
            return candidate;
        }
        List<String> pulseFiles = ProjectDiscovery.discoverPulseFiles(root);
        if (pulseFiles.size() == 1) {
            return pulseFiles.getString(0);
        }
        return null;
    }

    /**
     * Discovers every Pulse source file under the supplied root in stable path order.
     */
    public static List<String> discoverPulseFiles(String rootPath) {
        String root = Path.normalize((String) Objects.requireNonNull(rootPath, "rootPath must not be null"));
        ArrayList<String> out = new ArrayList<String>();
        if (!File.isDirectory(root)) {
            return out;
        }
        List<String> files = Files.listFilesRecursive(root);
        int index = 0;
        while (index < files.size()) {
            String file = files.getString(index);
            if (Path.extension(file).equals("pulse")) {
                ProjectDiscovery.addSortedDistinct(out, Path.normalize(file));
            }
            index = index + 1;
        }
        return out;
    }

    /**
     * Discovers every Pulse test file under the supplied tests root in stable path order.
     */
    public static List<String> discoverTestFiles(String testsRoot) {
        return ProjectDiscovery.discoverPulseFiles(testsRoot);
    }

    private static void addSortedDistinct(ArrayList<String> out, String value) {
        int index = 0;
        while (index < out.size()) {
            String current = out.getString(index);
            int compare = value.compareTo(current);
            if (compare == 0) {
                return;
            }
            if (compare < 0) {
                out.add(index, value);
                return;
            }
            index = index + 1;
        }
        out.add(value);
    }
}
