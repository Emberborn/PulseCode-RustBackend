package pulse.concurrent;

import pulse.lang.Runnable;
import pulse.lang.Thread;
import pulse.lang.Throwable;

/**
 * Executor-owned race bridge for `CompletableFuture.runAfterEitherAsync`.
 */
public final class CompletableRunAfterEitherTask<T> implements Runnable {
    private CompletableFuture<T> left;
    private CompletableFuture<T> right;
    private Runnable action;
    private CompletableFuture<Object> target;

    /**
     * Creates one race action bridge.
     */
    public CompletableRunAfterEitherTask(
        CompletableFuture<T> left,
        CompletableFuture<T> right,
        Runnable action,
        CompletableFuture<Object> target
    ) {
        this.left = left;
        this.right = right;
        this.action = action;
        this.target = target;
    }

    private CompletableFuture<T> awaitWinner() {
        while (true) {
            if (this.left.await(0L)) {
                return this.left;
            }
            if (this.right.await(0L)) {
                return this.right;
            }
            Thread.yieldNow();
        }
        return this.left;
    }

    /**
     * Waits for either source stage, runs the action, and completes the target.
     */
    public void run() {
        try {
            this.awaitWinner().get();
            this.action.run();
            this.target.complete(null);
        } catch (Throwable failure) {
            this.target.completeExceptionally(failure);
        }
    }
}
