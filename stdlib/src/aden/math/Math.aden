    /**
     * Returns `exp(value) - 1` while preserving more accuracy near zero.
     * Use this when exponential growth is being measured relative to a zero baseline.
     */
    public static double expm1(double value) {
        if (isNaN(value)) {
            return NAN;
        }
        if (value == POSITIVE_INFINITY) {
            return POSITIVE_INFINITY;
        }
        if (value == NEGATIVE_INFINITY) {
            return -1.0d;
        }
        if (abs(value) < 0.000001d) {
            double term = value;
            double sum = value;
            int n = 2;
            while (n < 18) {
                term = term * value / (double) n;
                sum = sum + term;
                n = n + 1;
            }
            return sum;
        }
        return exp(value) - 1.0d;
    }

