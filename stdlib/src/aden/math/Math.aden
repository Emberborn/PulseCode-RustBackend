        if (start == 0.0f) {
            if (direction > 0.0f) {
                return smallestPositiveFloat();
            }
            return copySign(smallestPositiveFloat(), -1.0f);
        }
        float step = ulp(start);
        if (direction > start) {
            return start + step;
        }
        return start - step;
    }

