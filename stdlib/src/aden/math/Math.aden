    /**
     * Returns the cube root of the supplied value.
     * Use this for practical real-valued root helpers in the current math closure.
     */
    public static double cbrt(double value) {
        if (isNaN(value) || isInfinite(value) || value == 0.0d) {
            return value;
        }
        boolean negative = value < 0.0d;
        double magnitude = abs(value);
        double guess = magnitude > 1.0d ? magnitude : 1.0d;
        int iterations = 0;
        while (iterations < 24) {
            guess = ((2.0d * guess) + (magnitude / (guess * guess))) / 3.0d;
            iterations = iterations + 1;
        }
        if (negative) {
            return 0.0d - guess;
        }
        return guess;
    }

