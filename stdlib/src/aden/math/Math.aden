        if (abs(value) < 0.000001d) {
            double term = value;
            double sum = value;
            int n = 2;
            while (n < 24) {
                term = term * (0.0d - value);
                sum = sum + (term / (double) n);
                n = n + 1;
            }
            return sum;
        }
        return log(1.0d + value);
    }

