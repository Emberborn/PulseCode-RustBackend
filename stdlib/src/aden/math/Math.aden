    /**
     * Returns the arc-tangent of the supplied float value in radians.
     * Use this for practical inverse-trigonometric helpers while staying on the float lane.
     */
    public static float atan(float value) {
        return (float) atan((double) value);
    }

    /**
     * Returns the arc-tangent of the supplied value in radians.
     * Use this for practical inverse-trigonometric helpers in the current math closure.
     */
    public static double atan(double value) {
        if (isNaN(value)) {
            return NAN;
        }
        if (value == POSITIVE_INFINITY) {
            return PI / 2.0d;
        }
        if (value == NEGATIVE_INFINITY) {
            return 0.0d - (PI / 2.0d);
        }
        if (value == 0.0d) {
            return 0.0d;
        }
        if (value < 0.0d) {
            return 0.0d - atan(0.0d - value);
        }
        if (value > 2.414213562373095d) {
            return (PI / 2.0d) - atan(1.0d / value);
        }
        if (value > 0.414213562373095d) {
            return (PI / 4.0d) + atan((value - 1.0d) / (value + 1.0d));
        }

        double term = value;
        double sum = value;
        int n = 1;
        while (n < 24) {
            term = term * (0.0d - (value * value));
            sum = sum + (term / (double) (2 * n + 1));
            n = n + 1;
        }
        return sum;
    }

