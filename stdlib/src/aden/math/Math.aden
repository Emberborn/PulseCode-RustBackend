    public static ubyte clamp(ubyte value, ubyte low, ubyte high) {
        requireClampRange((long) low, (long) high);
        if (value < low) {
            return low;
        }
        if (value > high) {
            return high;
        }
        return value;
    }

    /**
     * Clamps an unsigned short into the inclusive low/high range.
