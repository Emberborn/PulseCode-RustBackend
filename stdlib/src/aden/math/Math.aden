    /**
     * Returns the two-argument arc-tangent of the supplied y/x pair in radians.
     * Use this for practical quadrant-aware inverse-trigonometric helpers in the current math closure.
     * The current baseline returns `0.0d` for `atan2(0.0d, 0.0d)`.
     */
    public static double atan2(double y, double x) {
        if (isNaN(y) || isNaN(x)) {
            return NAN;
        }
        if (x == 0.0d && y == 0.0d) {
            return 0.0d;
        }
        if (x > 0.0d) {
            return atan(y / x);
        }
        if (x < 0.0d && y >= 0.0d) {
            return atan(y / x) + PI;
        }
        if (x < 0.0d && y < 0.0d) {
            return atan(y / x) - PI;
        }
        if (x == 0.0d && y > 0.0d) {
            return PI / 2.0d;
        }
        if (x == 0.0d && y < 0.0d) {
            return 0.0d - (PI / 2.0d);
        }
        return 0.0d;
    }

