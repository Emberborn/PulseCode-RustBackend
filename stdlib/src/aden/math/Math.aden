    /**
     * Returns the mathematical floor division result for two integers.
     * Use this when negative operands should round toward negative infinity instead of zero.
     */
    public static int floorDiv(int dividend, int divisor) {
        int quotient = dividend / divisor;
        int remainder = dividend % divisor;
        if (remainder != 0 && ((dividend < 0 && divisor > 0) || (dividend > 0 && divisor < 0))) {
            return quotient - 1;
        }
        return quotient;
    }

    /**
     * Returns the mathematical floor division result for two longs.
     * Use this when negative long operands should round toward negative infinity instead of zero.
     */
    public static long floorDiv(long dividend, long divisor) {
        long quotient = dividend / divisor;
        long remainder = dividend % divisor;
        if (remainder != 0L && ((dividend < 0L && divisor > 0L) || (dividend > 0L && divisor < 0L))) {
            return quotient - 1L;
        }
        return quotient;
    }

    public static byte floorDiv(byte dividend, byte divisor) { return (byte) floorDiv((int) dividend, (int) divisor); }
    public static short floorDiv(short dividend, short divisor) { return (short) floorDiv((int) dividend, (int) divisor); }
    public static char floorDiv(char dividend, char divisor) { return (char) (((int) dividend) / ((int) divisor)); }
    public static ubyte floorDiv(ubyte dividend, ubyte divisor) { return (ubyte) (((int) dividend) / ((int) divisor)); }
    public static ushort floorDiv(ushort dividend, ushort divisor) { return (ushort) (((int) dividend) / ((int) divisor)); }

    /**
     * Returns the floor division result for two unsigned ints.
     * Unsigned operands are already non-negative, so this follows ordinary integer division.
     */
    public static uint floorDiv(uint dividend, uint divisor) {
        return dividend / divisor;
    }

    /**
     * Returns the floor division result for two unsigned longs.
     * Unsigned operands are already non-negative, so this follows ordinary long division.
     */
    public static ulong floorDiv(ulong dividend, ulong divisor) {
        return dividend / divisor;
    }

    /**
     * Returns the mathematical floor modulus result for two integers.
     * Use this when the remainder should keep the divisor sign instead of truncation semantics.
     */
    public static int floorMod(int dividend, int divisor) {
        return dividend - (floorDiv(dividend, divisor) * divisor);
    }

    /**
     * Returns the mathematical floor modulus result for two longs.
     * Use this when the remainder should keep the divisor sign instead of truncation semantics.
     */
    public static long floorMod(long dividend, long divisor) {
        return dividend - (floorDiv(dividend, divisor) * divisor);
    }

    public static byte floorMod(byte dividend, byte divisor) { return (byte) floorMod((int) dividend, (int) divisor); }
    public static short floorMod(short dividend, short divisor) { return (short) floorMod((int) dividend, (int) divisor); }
    public static char floorMod(char dividend, char divisor) { return (char) (((int) dividend) % ((int) divisor)); }
    public static ubyte floorMod(ubyte dividend, ubyte divisor) { return (ubyte) (((int) dividend) % ((int) divisor)); }
    public static ushort floorMod(ushort dividend, ushort divisor) { return (ushort) (((int) dividend) % ((int) divisor)); }

    /**
     * Returns the floor modulus result for two unsigned ints.
     * Unsigned operands are already non-negative, so this follows ordinary remainder semantics.
     */
    public static uint floorMod(uint dividend, uint divisor) {
        return dividend % divisor;
    }

    /**
     * Returns the floor modulus result for two unsigned longs.
     * Unsigned operands are already non-negative, so this follows ordinary remainder semantics.
     */
    public static ulong floorMod(ulong dividend, ulong divisor) {
        return dividend % divisor;
    }

    private static double normalizeRadians(double radians) {
        double fullTurn = PI * 2.0d;
        double reduced = radians % fullTurn;
        if (reduced > PI) {
            reduced = reduced - fullTurn;
        }
        if (reduced < (0.0d - PI)) {
            reduced = reduced + fullTurn;
        }
        return reduced;
    }

    private static double sinKernel(double radians) {
        double term = radians;
        double sum = radians;
        int n = 1;
        while (n < 12) {
            double denominator = (double) ((2 * n) * (2 * n + 1));
            term = term * (0.0d - (radians * radians)) / denominator;
            sum = sum + term;
            n = n + 1;
        }
        return sum;
    }

    private static double cosKernel(double radians) {
        double term = 1.0d;
        double sum = 1.0d;
        int n = 1;
        while (n < 12) {
            double denominator = (double) ((2 * n - 1) * (2 * n));
            term = term * (0.0d - (radians * radians)) / denominator;
            sum = sum + term;
            n = n + 1;
        }
        return sum;
    }

    private static void requireClampRange(long low, long high) {
        if (low > high) {
            throw new IllegalArgumentException("Math.clamp(...) requires low <= high");
        }
    }

    private static void requireUnsignedClampRange(uint low, uint high) {
        if (low > high) {
            throw new IllegalArgumentException("Math.clamp(...) requires low <= high");
        }
    }

    private static void requireUnsignedClampRange(ulong low, ulong high) {
        if (low > high) {
            throw new IllegalArgumentException("Math.clamp(...) requires low <= high");
        }
    }

    private static boolean hasNegativeSign(float value) {
        if (value < 0.0f) {
            return true;
        }
        if (value == 0.0f) {
            return (1.0f / value) == (0.0f - (1.0f / 0.0f));
        }
        return false;
    }

    private static boolean hasNegativeSign(double value) {
        if (value < 0.0d) {
            return true;
        }
        if (value == 0.0d) {
            return (1.0d / value) == NEGATIVE_INFINITY;
        }
        return false;
    }

    private static double expSeries(double value) {
        double term = 1.0d;
        double sum = 1.0d;
        int n = 1;
        while (n < 28) {
            term = term * value / (double) n;
            sum = sum + term;
            n = n + 1;
        }
        return sum;
    }

    private static double scaleByPowerOfTwo(double value, int exponent) {
        double scaled = value;
        int remaining = exponent;
        while (remaining > 0) {
            scaled = scaled * 2.0d;
            if (isInfinite(scaled)) {
                return scaled;
            }
            remaining = remaining - 1;
        }
        while (remaining < 0) {
            scaled = scaled * 0.5d;
            if (scaled == 0.0d) {
                return scaled;
            }
            remaining = remaining + 1;
        }
        return scaled;
    }

    private static float buildFloatMinValue() {
        float value = 1.4012985f;
        int i = 0;
        while (i < 45) {
            value = value / 10.0f;
            i = i + 1;
        }
        return value;
    }

    private static float buildFloatMinNormal() {
        return (float) pow(2.0d, -126);
    }

    private static float buildFloatMaxValue() {
        float value = 3.4028235f;
        int i = 0;
        while (i < 38) {
            value = value * 10.0f;
            i = i + 1;
        }
        return value;
    }

    private static double buildDoubleMinValue() {
        double value = 4.9406564584124654d;
        int i = 0;
        while (i < 324) {
            value = value / 10.0d;
            i = i + 1;
        }
        return value;
    }

    private static double buildDoubleMinNormal() {
        return pow(2.0d, -1022);
    }

    private static double buildDoubleMaxValue() {
        double value = 1.7976931348623157d;
        int i = 0;
        while (i < 308) {
            value = value * 10.0d;
            i = i + 1;
        }
        return value;
    }

    private static float smallestPositiveFloat() {
        if (FLOAT_MIN_VALUE == 0.0f) {
            return FLOAT_MIN_NORMAL;
        }
        return FLOAT_MIN_VALUE;
    }

    private static double smallestPositiveDouble() {
        if (DOUBLE_MIN_VALUE == 0.0d) {
            return DOUBLE_MIN_NORMAL;
        }
        return DOUBLE_MIN_VALUE;
    }
}
