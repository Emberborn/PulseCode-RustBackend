     * Use this for practical logarithmic helpers while staying on the float lane.
     */
    public static float log(float value) {
        return (float) log((double) value);
    }

    /**
     * Returns the natural logarithm of the supplied positive value.
     * Use this for practical logarithmic helpers in the current math closure.
     */
    public static double log(double value) {
        if (isNaN(value)) {
            return NAN;
        }
        if (value == POSITIVE_INFINITY) {
            return POSITIVE_INFINITY;
        }
        if (value == 0.0d) {
            return NEGATIVE_INFINITY;
        }
        if (value < 0.0d) {
            return NAN;
        }

        double scaled = value;
        int exponent = 0;
        while (scaled > SQRT_TWO) {
            scaled = scaled * 0.5d;
            exponent = exponent + 1;
        }
        while (scaled < SQRT_ONE_HALF) {
            scaled = scaled * 2.0d;
            exponent = exponent - 1;
        }

        double z = (scaled - 1.0d) / (scaled + 1.0d);
        double zSquared = z * z;
        double term = z;
        double sum = 0.0d;
        int denominator = 1;
        int iterations = 0;
        while (iterations < 16) {
            sum = sum + (term / (double) denominator);
            term = term * zSquared;
            denominator = denominator + 2;
            iterations = iterations + 1;
        }

        return (2.0d * sum) + (((double) exponent) * LN2);
    }

