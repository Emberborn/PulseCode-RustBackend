    /**
     * Returns the floating-point value adjacent to `start` in the direction of `direction`.
     * Use this when numeric code needs a deterministic next-step helper around a float value.
     */
    public static float nextAfter(float start, float direction) {
        if (isNaN(start) || isNaN(direction)) {
            return start + direction;
        }
        if (start == direction) {
            return direction;
        }
        if (start == (1.0f / 0.0f)) {
            if (direction < start) {
                return FLOAT_MAX_VALUE;
            }
            return start;
        }
        if (start == (0.0f - (1.0f / 0.0f))) {
            if (direction > start) {
                return 0.0f - FLOAT_MAX_VALUE;
            }
            return start;
