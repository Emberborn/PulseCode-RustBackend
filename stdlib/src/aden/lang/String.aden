        if (value == 'L') { return 'l'; }
        if (value == 'M') { return 'm'; }
        if (value == 'N') { return 'n'; }
        if (value == 'O') { return 'o'; }
        if (value == 'P') { return 'p'; }
        if (value == 'Q') { return 'q'; }
        if (value == 'R') { return 'r'; }
        if (value == 'S') { return 's'; }
        if (value == 'T') { return 't'; }
        if (value == 'U') { return 'u'; }
        if (value == 'V') { return 'v'; }
        if (value == 'W') { return 'w'; }
        if (value == 'X') { return 'x'; }
        if (value == 'Y') { return 'y'; }
        if (value == 'Z') { return 'z'; }
        return value;
    }

    private static char toUpperAscii(char value) {
        if (value == 'a') { return 'A'; }
        if (value == 'b') { return 'B'; }
        if (value == 'c') { return 'C'; }
