    /**
     * Returns the one-character decimal text for the supplied digit.
     * Use this internally for stdlib-owned integer formatting.
     */
    private static String digitText(int digit) {
        if (digit == 0) {
            return "0";
        }
        if (digit == 1) {
            return "1";
        }
        if (digit == 2) {
            return "2";
        }
        if (digit == 3) {
            return "3";
        }
        if (digit == 4) {
            return "4";
        }
        if (digit == 5) {
            return "5";
        }
        if (digit == 6) {
            return "6";
        }
        if (digit == 7) {
            return "7";
        }
        if (digit == 8) {
            return "8";
        }
        return "9";
    }

    private static char toLowerAscii(char value) {
        if (value == 'A') { return 'a'; }
        if (value == 'B') { return 'b'; }
        if (value == 'C') { return 'c'; }
        if (value == 'D') { return 'd'; }
        if (value == 'E') { return 'e'; }
        if (value == 'F') { return 'f'; }
        if (value == 'G') { return 'g'; }
        if (value == 'H') { return 'h'; }
