        if (value == 'w') { return 'W'; }
        if (value == 'x') { return 'X'; }
        if (value == 'y') { return 'Y'; }
        if (value == 'z') { return 'Z'; }
        return value;
    }

    private static boolean isAsciiWhitespace(char value) {
        return value == ' ' || value == '\t' || value == '\n' || value == '\r';
    }
