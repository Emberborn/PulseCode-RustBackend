        if (value == 'j') { return 'J'; }
        if (value == 'k') { return 'K'; }
        if (value == 'l') { return 'L'; }
        if (value == 'm') { return 'M'; }
        if (value == 'n') { return 'N'; }
        if (value == 'o') { return 'O'; }
        if (value == 'p') { return 'P'; }
        if (value == 'q') { return 'Q'; }
